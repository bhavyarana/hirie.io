SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Mistral AI — get your key at https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_mistral_api_key
# Available models: mistral-large-latest, mistral-small-latest, open-mixtral-8x7b
MISTRAL_MODEL=mistral-small-latest

# Redis — for production use a managed Redis (Railway, Upstash, Redis Cloud)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                  # Required in production
REDIS_TLS=false                  # Set to true for managed Redis (Upstash, Railway)

# API Server
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# BullMQ Worker (run separately: npm run worker)
WORKER_CONCURRENCY=3             # Jobs processed in parallel per worker instance
WORKER_HEALTH_PORT=3002          # HTTP health probe port for the worker process
WORKER_LOCK_DURATION=300000      # ms — how long a job can run before being considered stalled (5 min)
WORKER_SHUTDOWN_TIMEOUT=90000    # ms — how long to wait for in-flight jobs on SIGTERM (90 s)
